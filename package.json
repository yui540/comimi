{
  "name": "@yui540/comimi",
  "version": "0.17.0",
  "description": "Open-source comic reader library for JS/TS",
  "keywords": [
    "manga",
    "comic",
    "viewer",
    "reader",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "locales",
    "docs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite examples/preview --host 0.0.0.0",
    "build": "tsc --noEmit && vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview examples/preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
